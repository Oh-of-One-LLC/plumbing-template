---
import "../styles/global.css";
import Header from "../components/header.astro";
import Footer from "../components/footer/footer-with-form.astro";
import { COMPANY_NAME as companyName, PHONE as phone } from "../config";

const menuItems = [
  { name: "Services", href: "/#services" },
  { name: "About", href: "/#about" },
  { name: "Contact", href: "/#contact" },
];

const { pageTitle = companyName, logo } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content="Plumbers you can trust" />
    <meta name="theme-color" content="#1d4ed8" />
  </head>

  <body class="bg-background text-text min-h-full antialiased">
    <div class="flex min-h-screen flex-col" id="top">
      <Header logo={logo} menuItems={menuItems} phone={phone} />

      <main class="max-w-90vw flex-1" role="main">
        <slot name="main" />
      </main>

      <Footer companyName={companyName} phone={phone} />
    </div>
  </body>
</html>
