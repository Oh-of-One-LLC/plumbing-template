---
import "../styles/global.css";
import Header from "../components/header.astro";
import FooterBasic from "../components/footer-basic.astro";

const menuItems = [
  {
    name: "Services",
    href: "/#services",
  },
  {
    name: "Call",
    href: "/#call",
  },
];

const logo = "Logo";
const companyName = "Smith & Sons Plumbing";
---

<!doctype html>
<html lang="en" class="h-full scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Smith and Sons Plumbing</title>
    <meta name="description" content="Plumbers you can trust" />
    <meta name="theme-color" content="#1d4ed8" />
  </head>

  <body class="min-h-full bg-white text-zinc-900 antialiased">
    <div class="flex min-h-screen flex-col" id="top">
      <Header logo={logo} menuItems={menuItems} />

      <main class="max-w-90vw" role="main"></main>

      <FooterBasic companyName={companyName} />
    </div>
  </body>
</html>
