---
import "../styles/global.css";
---

<!doctype html>
<html lang="en" class="h-full scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Smith and Sons Plumbing</title>
    <meta name="description" content="Plumbers you can trust" />
    <meta name="theme-color" content="#1d4ed8" />
  </head>

  <body class="min-h-full bg-white text-zinc-900 antialiased">
    <div class="flex min-h-screen flex-col">
      <slot name="header" />
      <main class="flex-1">
        <!-- Hero -->
        <section class="bg-blue-600 text-white">
          <div class="mx-auto max-w-7xl px-6 lg:px-8 py-24 lg:py-32">
            <div class="max-w-3xl">
              <h1
                class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl"
              >
                Trusted Plumbing Services in Austin, TX
              </h1>

              <p class="mt-6 text-lg text-blue-100 sm:text-xl">
                Licensed & insured professionals providing fast, affordable
                residential and commercial plumbing solutions.
              </p>

              <div class="mt-10 flex flex-col sm:flex-row gap-4">
                <a
                  href="tel:+15125551234"
                  class="rounded-lg bg-white px-6 py-3 font-semibold text-blue-600 hover:bg-zinc-100 focus-visible:ring-2 focus-visible:ring-white"
                >
                  📞 Call (512) 555-1234
                </a>

                <a
                  href="#contact"
                  class="rounded-lg border border-white px-6 py-3 font-semibold hover:bg-white/10"
                >
                  Request Free Estimate
                </a>
              </div>

              <p class="mt-6 text-sm text-blue-200">
                Same-day service available • Emergency repairs • 5-star rated
              </p>
            </div>
          </div>
        </section>

        <!-- Services -->
        <section id="services" class="py-20">
          <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="max-w-2xl">
              <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
                Our Plumbing Services
              </h2>
              <p class="mt-4 text-zinc-600">
                Complete plumbing solutions for homes and businesses.
              </p>
            </div>

            <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
              <div class="rounded-xl border border-zinc-200 p-8">
                <h3 class="font-semibold text-lg">Emergency Repairs</h3>
                <p class="mt-4 text-zinc-600">
                  24/7 rapid response for leaks, burst pipes, and urgent
                  plumbing issues.
                </p>
              </div>

              <div class="rounded-xl border border-zinc-200 p-8">
                <h3 class="font-semibold text-lg">Water Heater Installation</h3>
                <p class="mt-4 text-zinc-600">
                  Tank and tankless water heater replacement and maintenance.
                </p>
              </div>

              <div class="rounded-xl border border-zinc-200 p-8">
                <h3 class="font-semibold text-lg">Drain Cleaning</h3>
                <p class="mt-4 text-zinc-600">
                  Advanced equipment to remove stubborn clogs safely.
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- Why Choose Us -->
        <section id="about" class="bg-zinc-50 py-20 border-t border-zinc-200">
          <div
            class="mx-auto max-w-7xl px-6 lg:px-8 grid gap-12 lg:grid-cols-2"
          >
            <div>
              <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
                Why Homeowners Choose Us
              </h2>

              <ul class="mt-8 space-y-4 text-zinc-600">
                <li>✔ Licensed & insured technicians</li>
                <li>✔ Upfront pricing — no hidden fees</li>
                <li>✔ 15+ years of local experience</li>
                <li>✔ Satisfaction guaranteed</li>
              </ul>
            </div>

            <div class="rounded-xl bg-white p-8 shadow-sm">
              <p class="text-lg font-medium">
                “Fast, professional, and honest. They fixed our leak the same
                day we called.”
              </p>
              <p class="mt-4 text-sm text-zinc-500">— Sarah M., Austin TX</p>
            </div>
          </div>
        </section>

        <!-- CTA -->
        <section id="contact" class="bg-blue-600 py-20 text-white">
          <div class="mx-auto max-w-4xl px-6 text-center">
            <h2 class="text-3xl font-bold sm:text-4xl">
              Need a Reliable Plumber Today?
            </h2>
            <p class="mt-4 text-blue-100">
              Call now or request your free estimate online.
            </p>

            <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="tel:+15125551234"
                class="rounded-lg bg-white px-6 py-3 font-semibold text-blue-600 hover:bg-zinc-100"
              >
                📞 Call (512) 555-1234
              </a>

              <a
                href="#"
                class="rounded-lg border border-white px-6 py-3 font-semibold hover:bg-white/10"
              >
                Request Estimate
              </a>
            </div>
          </div>
        </section>
      </main>

      <!-- Footer -->
      <footer class="border-t border-zinc-200 py-10 bg-white">
        <div class="mx-auto max-w-7xl px-6 lg:px-8 text-sm text-zinc-500">
          <div class="flex flex-col gap-4 sm:flex-row justify-between">
            <div>
              <p class="font-semibold text-zinc-900">Smith & Sons Plumbing</p>
              <p>123 Main Street, Austin, TX</p>
              <p>(512) 555-1234</p>
            </div>

            <div>
              <p>© Smith & Sons Plumbing. All rights reserved.</p>
              <div class="mt-2 flex gap-4">
                <a href="#" class="hover:text-zinc-900">Privacy</a>
                <a href="#" class="hover:text-zinc-900">Terms</a>
              </div>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
