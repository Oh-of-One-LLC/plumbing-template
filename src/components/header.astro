---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface MenuItem {
  name: string;
  href: string;
}

interface Props {
  logo: string | ImageMetadata;
  menuItems: MenuItem[];
  phone?: string;
}

const { menuItems, logo, phone } = Astro.props;
---

<header class="bg-brand text-brand-fg border-border sticky top-0 z-50 border-b">
  <div
    class="mx-8 flex h-20 max-w-9/10 items-center justify-between sm:px-8 lg:mx-auto lg:px-12"
  >
    <a
      href="/#top"
      class="focus:ring-accent focus:ring-offset-raised flex h-full items-center py-3 text-lg font-semibold transition-all hover:opacity-80 focus:ring-2 focus:ring-offset-2 focus:outline-none lg:text-2xl"
      >{
        typeof logo === "string" ? (
          logo
        ) : (
          <Image
            src={logo}
            alt=""
            class="h-full w-auto rounded-lg object-contain"
          />
        )
      }</a
    >
    <!-- Desktop Nav -->
    <nav class="hidden gap-8 text-base font-medium md:flex">
      {
        (menuItems ?? []).map((item) => (
          <a
            href={item.href}
            class="focus:ring-accent focus:ring-offset-raised text-lg transition-all hover:opacity-80 focus:ring-2 focus:ring-offset-2 focus:outline-none"
          >
            {item.name}
          </a>
        ))
      }
    </nav>

    <!-- Desktop Phone -->
    {
      phone && (
        <a
          href={`tel:${phone}`}
          class="text-accent focus:ring-accent focus:ring-offset-raised hidden items-center gap-2 text-xl font-bold transition hover:opacity-80 focus:ring-2 focus:ring-offset-2 focus:outline-none md:flex"
          aria-label={`Call us at ${phone}`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.49 5.49l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          {phone}
        </a>
      )
    }

    <!-- Mobile Button -->
    <button
      id="menu-btn"
      class="focus:ring-accent focus:ring-offset-raised rounded-lg p-4 text-3xl transition hover:opacity-80 focus:ring-2 focus:ring-offset-2 focus:outline-none md:hidden"
      aria-label="Toggle Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      ☰
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="bg-raised absolute max-h-0 w-full overflow-hidden transition-all duration-300 md:hidden"
  >
    <nav class="flex flex-col gap-4 pb-5 text-base font-medium">
      {
        (menuItems ?? []).map((item) => (
          <a
            href={item.href}
            class="focus:ring-offset-brand mx-8 text-lg opacity-80 focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
          >
            {item.name}
          </a>
        ))
      }
      {
        phone && (
          <a
            href={`tel:${phone}`}
            class="text-accent focus:ring-offset-brand mx-8 text-xl font-bold focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
            aria-label={`Call us at ${phone}`}
          >
            {phone}
          </a>
        )
      }
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = menu?.style.maxHeight;

    if (isOpen) {
      menu!.style.maxHeight = "";
      btn.setAttribute("aria-expanded", "false");
    } else {
      menu!.style.maxHeight = menu!.scrollHeight + "px";
      btn.setAttribute("aria-expanded", "true");
    }
  });

  menu!.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu!.style.maxHeight = "";
      btn?.setAttribute("aria-expanded", "false");
    });
  });
</script>
