---
import type { ImageMetadata } from "astro";

interface MenuItem {
  name: string;
  href: string;
}

interface Props {
  logo: string | ImageMetadata;
  menuItems: MenuItem[];
}

const { menuItems, logo } = Astro.props;
---

<header
  class="sticky top-0 z-50 bg-primary border-b border-slate-900 text-text-secondary"
>
  <div
    class="lg:mx-auto mx-8 max-w-9/10 h-20 sm:px-8 lg:px-12 flex items-center justify-between"
  >
    <a
      href="/#top"
      class="lg:text-2xl text-lg font-semibold hover:text-text-secondary-hover focus:outline-none
             focus:ring-1 focus:ring-slate-400 focus:ring-offset- focus:ring-offset-white
             focus:underline transition-all"
      >{logo}</a
    >
    <!-- Desktop Nav -->
    <nav class="hidden md:flex gap-8 text-base font-medium">
      {
        (menuItems ?? []).map((item) => (
          <a
            href={item.href}
            class="text-lg hover:text-text-secondary-hover focus:outline-none focus:ring-1
                 focus:ring-slate-400 focus:ring-offset- focus:ring-offset-white
                   focus:underline transition-all"
          >
            {item.name}
          </a>
        ))
      }
    </nav>

    <!-- Mobile Button -->
    <button
      id="menu-btn"
      class="md:hidden p-4 rounded-lg hover:bg-slate-100 transition text-3xl text-accent-light
             hover:text-accent-light-hover"
      aria-label="Toggle Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      ☰
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden transition-all duration-300 max-h-0 absolute w-full
         bg-primary"
  >
    <nav class="flex flex-col gap-4 text-base font-medium pb-5">
      {
        (menuItems ?? []).map((item) => (
          <a href={item.href} class="mx-8 text-lg">
            {item.name}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = menu?.style.maxHeight;

    if (isOpen) {
      menu!.style.maxHeight = "";
      btn.setAttribute("aria-expanded", "false");
    } else {
      menu!.style.maxHeight = menu!.scrollHeight + "px";
      btn.setAttribute("aria-expanded", "true");
    }

    menu!.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu!.style.maxHeight = "";
        btn.setAttribute("aria-expanded", "false");
      });
    });
  });
</script>
