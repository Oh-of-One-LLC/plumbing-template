---
import type { ImageMetadata } from "astro";

interface MenuItem {
  name: string;
  href: string;
}

interface Props {
  logo: string | ImageMetadata;
  menuItems: MenuItem[];
}

const { menuItems, logo } = Astro.props;
---

<header
  class="bg-brand text-brand-fg sticky top-0 z-50 border-b border-slate-900"
>
  <div
    class="mx-8 flex h-20 max-w-9/10 items-center justify-between sm:px-8 lg:mx-auto lg:px-12"
  >
    <a
      href="/#top"
      class="hover:text-brand-fg-muted focus:ring-accent focus:ring-offset-surface text-lg font-semibold transition-all focus:ring-2 focus:ring-offset-2 lg:text-2xl"
      >{logo}</a
    >
    <!-- Desktop Nav -->
    <nav class="hidden gap-8 text-base font-medium md:flex">
      {
        (menuItems ?? []).map((item) => (
          <a
            href={item.href}
            class="hover:text-brand-fg-muted focus:ring-accent focus:ring-offset-surface text-lg transition-all focus:ring-2 focus:ring-offset-2"
          >
            {item.name}
          </a>
        ))
      }
    </nav>

    <!-- Mobile Button -->
    <button
      id="menu-btn"
      class="rounded-lg p-4 text-3xl transition hover:bg-slate-100 md:hidden"
      aria-label="Toggle Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      ☰
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="bg-brand absolute max-h-0 w-full overflow-hidden transition-all duration-300 md:hidden"
  >
    <nav class="flex flex-col gap-4 pb-5 text-base font-medium">
      {
        (menuItems ?? []).map((item) => (
          <a href={item.href} class="mx-8 text-lg">
            {item.name}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = menu?.style.maxHeight;

    if (isOpen) {
      menu!.style.maxHeight = "";
      btn.setAttribute("aria-expanded", "false");
    } else {
      menu!.style.maxHeight = menu!.scrollHeight + "px";
      btn.setAttribute("aria-expanded", "true");
    }
  });

  menu!.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu!.style.maxHeight = "";
      btn?.setAttribute("aria-expanded", "false");
    });
  });
</script>
