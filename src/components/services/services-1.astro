---

<section
  id="services"
  aria-labelledby="services-heading"
  class="bg-background text-text w-full px-8 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl">
    <div class="mb-12 flex flex-col gap-4 text-center md:mb-16">
      <h2
        id="services-heading"
        class="text-4xl font-bold tracking-tight md:text-5xl"
      >
        Our Services
      </h2>
      <p class="text-text-muted mx-auto max-w-xl text-lg">
        From routine maintenance to emergency call-outs, we've got every
        plumbing need covered.
      </p>
    </div>

    <ul
      class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
      role="list"
    >
      {
        services.map((service) => (
          <li class="border-border bg-surface flex flex-col gap-4 rounded-lg border p-6">
            <div
              class="text-brand-red bg-raised flex h-10 w-10 items-center justify-center rounded-lg"
              aria-hidden="true"
              set:html={service.icon}
            />
            <div class="flex flex-col gap-2">
              <h3 class="text-lg font-semibold">{service.title}</h3>
              <p class="text-text-muted">{service.description}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
