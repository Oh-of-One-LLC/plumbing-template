---
const services = [
  {
    title: "Emergency Repairs",
    description:
      "Burst pipe? Severe leak? We're available 24/7 to handle any plumbing emergency fast.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  },
  {
    title: "Drain Cleaning",
    description:
      "Slow or blocked drains cleared quickly using professional-grade equipment.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
  },
  {
    title: "Pipe Repair & Installation",
    description:
      "From pinhole leaks to full repiping — we handle every pipe job to code.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    title: "Water Heater Service",
    description:
      "Installation, repair, and maintenance for tank and tankless water heaters.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2c0 6-8 6-8 12a8 8 0 0 0 16 0c0-6-8-6-8-12z"/><path d="M12 22v-4"/></svg>`,
  },
  {
    title: "Bathroom & Kitchen Plumbing",
    description:
      "Faucets, toilets, sinks, and fixtures — installed or repaired to last.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><path d="M12 2v4"/><path d="M12 6a4 4 0 0 1 4 4v2H8v-2a4 4 0 0 1 4-4z"/></svg>`,
  },
  {
    title: "Commercial Plumbing",
    description:
      "Full-service plumbing solutions for offices, restaurants, and commercial buildings.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="16" height="20" x="4" y="2" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01M12 6h.01M16 6h.01M8 10h.01M12 10h.01M16 10h.01M8 14h.01M12 14h.01M16 14h.01"/></svg>`,
  },
];
---

<section
  id="services"
  aria-labelledby="services-heading"
  class="w-full bg-background px-8 py-24 text-text md:py-32"
>
  <div class="mx-auto max-w-5xl">
    <div class="mb-12 flex flex-col gap-4 text-center md:mb-16">
      <h2
        id="services-heading"
        class="text-4xl font-bold tracking-tight md:text-5xl"
      >
        Our Services
      </h2>
      <p class="mx-auto max-w-xl text-lg text-text-muted">
        From routine maintenance to emergency call-outs, we've got every
        plumbing need covered.
      </p>
    </div>

    <ul
      class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
      role="list"
    >
      {
        services.map((service) => (
          <li class="flex flex-col gap-4 rounded-lg border border-border bg-surface p-6">
            <div
              class="text-brand flex h-10 w-10 items-center justify-center rounded-lg bg-raised"
              aria-hidden="true"
              set:html={service.icon}
            />
            <div class="flex flex-col gap-2">
              <h3 class="text-lg font-semibold">{service.title}</h3>
              <p class="text-text-muted">{service.description}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
