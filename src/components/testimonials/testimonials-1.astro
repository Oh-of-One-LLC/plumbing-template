---
import { testimonials } from "../../data/testimonials";

const stars = Array(5).fill(null);
---

<section
  id="testimonials"
  aria-labelledby="testimonials-heading"
  class="bg-surface text-text w-full px-8 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl">
    <div class="mb-12 flex flex-col gap-4 text-center md:mb-16">
      <h2
        id="testimonials-heading"
        class="text-4xl font-bold tracking-tight md:text-5xl"
      >
        What Our Customers Say
      </h2>
      <p class="text-text-muted mx-auto max-w-xl text-lg">
        Don't just take our word for it — here's what real customers think.
      </p>
    </div>

    <ul
      class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
      role="list"
    >
      {
        testimonials.map((t) => (
          <li>
            <blockquote class="border-border bg-background flex h-full flex-col gap-4 rounded-lg border p-6">
              <div class="flex gap-1" role="img" aria-label="5 out of 5 stars">
                {stars.map(() => (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="text-amber-400"
                    aria-hidden="true"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                ))}
              </div>
              <p class="text-text-muted grow">"{t.quote}"</p>
              <footer>
                <cite class="not-italic">
                  <span class="text-text block font-semibold">{t.name}</span>
                  <span class="text-text-muted text-sm">{t.context}</span>
                </cite>
              </footer>
            </blockquote>
          </li>
        ))
      }
    </ul>
  </div>
</section>
