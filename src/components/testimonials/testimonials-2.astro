---
import { testimonials } from "../../data/testimonials";

const stars = Array(5).fill(null);
---

<section
  id="testimonials"
  aria-labelledby="testimonials-heading"
  class="bg-surface text-text relative w-full px-16 py-24 md:py-32"
>
  <div class="mx-auto max-w-3xl text-center">
    <!-- Stars -->
    <div class="mb-6 flex justify-center gap-1" aria-label="5 out of 5 stars">
      {
        stars.map(() => (
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="text-amber-400"
            aria-hidden="true"
          >
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
        ))
      }
    </div>

    <!-- Heading -->
    <h2
      id="testimonials-heading"
      class="mb-14 text-4xl font-bold tracking-tight md:text-5xl"
    >
      Don't take our word for it. Take theirs
    </h2>

    <!-- Slides — stacked in same grid cell so height is set by tallest -->
    <div class="grid" aria-live="polite" aria-atomic="true">
      {
        testimonials.map((t, i) => (
          <div
            class="testimonial-slide flex flex-col items-center gap-8 opacity-0 transition-opacity duration-500 [grid-area:1/1]"
            data-index={i}
            aria-hidden="true"
          >
            <blockquote class="flex flex-col items-center gap-6">
              <p class="text-xl leading-relaxed md:text-2xl">
                &ldquo;{t.quote}&rdquo;
              </p>
              <footer>
                <cite class="not-italic">
                  <span class="block font-bold">{t.name}</span>
                  <span class="text-text-muted text-sm">{t.context}</span>
                </cite>
              </footer>
            </blockquote>
          </div>
        ))
      }
    </div>

    <!-- Dot indicators -->
    <div
      class="mt-10 flex justify-center gap-3"
      role="tablist"
      aria-label="Testimonials"
    >
      {
        testimonials.map((t, i) => (
          <button
            class="testimonial-dot bg-border focus:ring-accent focus:ring-offset-surface h-2.5 w-2.5 cursor-pointer rounded-full transition-colors focus:ring-1 focus:ring-offset-2 focus:outline-none"
            data-index={i}
            role="tab"
            aria-label={`Testimonial from ${t.name}`}
            aria-selected="false"
          />
        ))
      }
    </div>
  </div>

  <!-- Prev arrow -->
  <button
    id="testimonials-prev"
    class="text-text-muted hover:text-text focus:ring-accent focus:ring-offset-surface absolute top-1/2 left-4 -translate-y-1/2 rounded-full p-3 transition focus:ring-1 focus:ring-offset-2 focus:outline-none md:left-8"
    aria-label="Previous testimonial"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="28"
      height="28"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M15 18l-6-6 6-6"></path>
    </svg>
  </button>

  <!-- Next arrow -->
  <button
    id="testimonials-next"
    class="text-text-muted hover:text-text focus:ring-accent focus:ring-offset-surface absolute top-1/2 right-4 -translate-y-1/2 rounded-full p-3 transition focus:ring-1 focus:ring-offset-2 focus:outline-none md:right-8"
    aria-label="Next testimonial"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="28"
      height="28"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M9 18l6-6-6-6"></path>
    </svg>
  </button>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>(".testimonial-slide");
  const dots = document.querySelectorAll<HTMLButtonElement>(".testimonial-dot");
  const prev = document.getElementById("testimonials-prev");
  const next = document.getElementById("testimonials-next");
  let current = 0;

  function show(index: number) {
    // Hide current
    slides[current].classList.remove("opacity-100");
    slides[current].classList.add("opacity-0", "pointer-events-none");
    slides[current].setAttribute("aria-hidden", "true");
    dots[current].classList.remove("bg-text");
    dots[current].classList.add("bg-border");
    dots[current].setAttribute("aria-selected", "false");

    // Show next
    current = ((index % slides.length) + slides.length) % slides.length;
    slides[current].classList.remove("opacity-0", "pointer-events-none");
    slides[current].classList.add("opacity-100");
    slides[current].setAttribute("aria-hidden", "false");
    dots[current].classList.remove("bg-border");
    dots[current].classList.add("bg-text");
    dots[current].setAttribute("aria-selected", "true");
  }

  // Initialise
  show(0);

  prev?.addEventListener("click", () => show(current - 1));
  next?.addEventListener("click", () => show(current + 1));
  dots.forEach((dot, i) => dot.addEventListener("click", () => show(i)));
</script>
