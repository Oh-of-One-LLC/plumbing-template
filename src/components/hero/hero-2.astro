---
import { Picture } from "astro:assets";
import heroImage from "../../assets/hero.jpg";
---

<section
  class="bg-brand text-brand-fg relative w-full overflow-hidden px-8 py-24 md:py-32"
>
  <!-- Diagonal background accent -->
  <div
    class="bg-brand-subtle pointer-events-none absolute inset-y-0 right-0 w-2/3 origin-top-right -skew-x-6"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative mx-auto grid max-w-5xl grid-cols-1 items-center gap-16 md:grid-cols-2"
  >
    <!-- Text column -->
    <div class="flex flex-col gap-6">
      <div class="flex flex-col gap-2">
        <p class="text-accent text-sm font-semibold tracking-widest uppercase">
          Licensed &amp; Insured
        </p>
        <h1 class="text-5xl leading-tight font-bold tracking-tight md:text-6xl">
          Expert Plumbing<br />You Can Trust
        </h1>
      </div>
      <p class="text-brand-fg-muted max-w-md text-lg">
        Fast, reliable service for homes and businesses. Available 24/7 for
        emergencies.
      </p>
      <div class="mt-2 flex flex-col gap-4 sm:flex-row">
        <a
          href="/#call"
          class="bg-accent text-accent-fg focus:ring-accent focus:ring-offset-surface rounded-lg px-8 py-3 text-lg font-semibold transition hover:opacity-90 focus:ring-2 focus:ring-offset-2"
        >
          Get a Free Quote
        </a>
        <a
          href="/#call"
          class="text-brand-fg focus:ring-accent focus:ring-offset-surface rounded-lg border border-white/30 px-8 py-3 text-lg font-semibold transition hover:bg-white/10 focus:ring-2 focus:ring-offset-2"
        >
          Call Now
        </a>
      </div>
    </div>

    <!-- Image column -->
    <Picture
      src={heroImage}
      formats={["avif", "webp"]}
      widths={[400, 700, 1000]}
      sizes="(max-width: 768px) 100vw, 50vw"
      alt="Expert plumber at work"
      class="w-full rounded-xl object-cover shadow-2xl"
    />
  </div>
</section>
