---
import { Image } from "astro:assets";
import { COMPANY_NAME as companyName } from "../../config";
import Denver from "../../assets/denver.jpg";
---

<section
  id="about"
  aria-labelledby="about-heading"
  class="bg-surface text-text w-full px-8 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl">
    <div class="flex flex-col gap-12 md:flex-row md:items-center md:gap-16">
      <div class="flex flex-col gap-6 md:flex-1">
        <h2
          id="about-heading"
          class="text-4xl font-bold tracking-tight md:text-5xl"
        >
          About {companyName}
        </h2>
        <p class="text-text-muted text-lg">
          At Lowe Plumbing, we believe every customer deserves honest work done
          right the first time. Dennis has spent years building a reputation on
          integrity, quality craftsmanship, and fair pricing — and that
          commitment shows in every job we take on. We're proud to serve the
          Colorado community and grateful for the trust you place in us.
        </p>
        <a
          href="/#contact"
          class="bg-brand text-brand-red-fg focus:ring-brand-red focus:ring-offset-surface mt-2 inline-flex w-fit rounded-lg px-8 py-3 text-lg font-semibold transition hover:opacity-80 focus:ring-2 focus:ring-offset-2 focus:outline-none"
        >
          Get in Touch
        </a>
      </div>

      <Image
        src={Denver}
        alt="Skyline of Denver, Colorado"
        class="w-110 rounded-sm shadow-lg"
        loading="lazy"
      />
    </div>
  </div>
</section>
