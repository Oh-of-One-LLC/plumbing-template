---

---

<section
  id="about"
  aria-labelledby="about-heading"
  class="bg-surface text-text w-full px-8 py-24 md:py-32"
>
  <div class="mx-auto max-w-5xl">
    <div class="flex flex-col gap-12 md:flex-row md:items-center md:gap-16">
      <div class="flex flex-col gap-6 md:flex-1">
        <h2
          id="about-heading"
          class="text-4xl font-bold tracking-tight md:text-5xl"
        >
          About Smith &amp; Sons Plumbing
        </h2>
        <p class="text-text-muted text-lg">
          Family-owned and operated for over 20 years, Smith &amp; Sons Plumbing
          has built a reputation for honest, high-quality work across
          residential and commercial properties.
        </p>
        <p class="text-text-muted text-lg">
          Our licensed plumbers are available around the clock — so you're never
          left without help when you need it most.
        </p>
        <a
          href="/#call"
          class="bg-brand text-brand-fg hover:bg-brand/90 focus:ring-accent focus:ring-offset-surface mt-2 inline-flex w-fit rounded-lg px-8 py-3 text-lg font-semibold transition focus:ring-2 focus:ring-offset-2"
        >
          Get in Touch
        </a>
      </div>

      <dl
        class="grid grid-cols-2 gap-4 md:flex-1"
        aria-label="Company highlights"
      >
        <div class="border-border flex flex-col gap-1 rounded-lg border p-6">
          <dt class="text-text-muted">Years in business</dt>
          <dd class="text-text text-3xl font-bold">20+</dd>
        </div>
        <div class="border-border flex flex-col gap-1 rounded-lg border p-6">
          <dt class="text-text-muted">Emergency service</dt>
          <dd class="text-text text-3xl font-bold">24/7</dd>
        </div>
        <div class="border-border flex flex-col gap-1 rounded-lg border p-6">
          <dt class="text-text-muted">Happy customers</dt>
          <dd class="text-text text-3xl font-bold">500+</dd>
        </div>
        <div class="border-border flex flex-col gap-1 rounded-lg border p-6">
          <dt class="text-text-muted">Licensed &amp; insured</dt>
          <dd class="text-text text-3xl font-bold">100%</dd>
        </div>
      </dl>
    </div>
  </div>
</section>
