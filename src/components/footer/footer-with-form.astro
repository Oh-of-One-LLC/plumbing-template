---
const { companyName, phone } = Astro.props;
---

<footer
  id="call"
  class="bg-brand text-brand-fg w-full px-8 py-16"
  aria-labelledby="footer-heading"
>
  <div class="mx-auto max-w-5xl">
    <div class="flex flex-col gap-12 md:flex-row md:gap-16">
      <!-- Company info + call link -->
      <div class="flex flex-col gap-6 md:w-64 md:shrink-0">
        <div class="flex flex-col gap-2">
          <h2 id="footer-heading" class="text-xl font-bold">{companyName}</h2>
          <p class="text-brand-fg-muted">
            Available 24/7 for emergencies. Call us or send a message and we'll
            get back to you as soon as possible.
          </p>
        </div>
        <a
          href={`tel:${phone}`}
          class="hover:text-brand-fg-muted focus:ring-offset-brand inline-flex items-center gap-2 text-lg font-semibold transition focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
          aria-label={`Call us at ${phone}`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.49 5.49l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          {phone}
        </a>
      </div>

      <!-- Contact form -->
      <div class="flex flex-1 flex-col gap-6">
        <h3 class="text-xl font-bold">Send Us a Message</h3>
        <form
          method="POST"
          action="#"
          class="flex flex-col gap-4"
          aria-label="Contact form"
        >
          <div class="flex flex-col gap-1">
            <label for="contact-name" class="text-sm font-medium">
              Name <span aria-hidden="true" class="text-red-400">*</span>
            </label>
            <input
              type="text"
              id="contact-name"
              name="name"
              autocomplete="name"
              required
              aria-required="true"
              placeholder="Jane Smith"
              class="text-brand-fg rounded-lg border border-zinc-700 bg-white/10 px-4 py-2.5 placeholder-zinc-500 transition focus:border-transparent focus:ring-2 focus:ring-white focus:outline-none"
            />
          </div>

          <div class="flex flex-col gap-4 sm:flex-row">
            <div class="flex flex-1 flex-col gap-1">
              <label for="contact-email" class="text-sm font-medium">
                Email <span aria-hidden="true" class="text-red-400">*</span>
              </label>
              <input
                type="email"
                id="contact-email"
                name="email"
                autocomplete="email"
                required
                aria-required="true"
                placeholder="jane@example.com"
                class="text-brand-fg rounded-lg border border-zinc-700 bg-white/10 px-4 py-2.5 placeholder-zinc-500 transition focus:border-transparent focus:ring-2 focus:ring-white focus:outline-none"
              />
            </div>
            <div class="flex flex-1 flex-col gap-1">
              <label for="contact-phone" class="text-sm font-medium">
                Phone number
              </label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                autocomplete="tel"
                placeholder="+1 (555) 000-0000"
                class="text-brand-fg rounded-lg border border-zinc-700 bg-white/10 px-4 py-2.5 placeholder-zinc-500 transition focus:border-transparent focus:ring-2 focus:ring-white focus:outline-none"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1">
            <label for="contact-message" class="text-sm font-medium">
              Message <span aria-hidden="true" class="text-red-400">*</span>
            </label>
            <textarea
              id="contact-message"
              name="message"
              rows="4"
              required
              aria-required="true"
              placeholder="Tell us about your plumbing issue..."
              class="text-brand-fg resize-y rounded-lg border border-zinc-700 bg-white/10 px-4 py-2.5 placeholder-zinc-500 transition focus:border-transparent focus:ring-2 focus:ring-white focus:outline-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="bg-brand-fg text-brand hover:bg-brand-fg-muted focus:ring-offset-brand mt-2 w-full rounded-lg px-8 py-3 text-lg font-semibold transition focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none sm:w-fit"
          >
            Send Message
          </button>

          <p class="text-brand-fg-muted mt-2 text-sm">
            By submitting this form, you agree to our <a
              href="/terms-of-use"
              class="hover:text-brand-fg focus:ring-offset-brand italic transition-all focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
              >Terms of Use</a
            > and <a
              href="/privacy-policy"
              class="hover:text-brand-fg focus:ring-offset-brand italic transition-all focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
              >Privacy Policy</a
            >.
          </p>
        </form>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-center gap-4 border-t border-zinc-800 pt-8 sm:flex-row sm:justify-between"
    >
      <p class="text-brand-fg-muted text-center text-sm">
        &copy; <span id="footer-year"></span>
        {companyName}. All Rights Reserved.
      </p>
      <p class="text-brand-fg-muted text-center text-sm">
        Demo by <a
          href="https://ohofone.com"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-brand-fg italic transition-all focus:ring-2 focus:ring-white focus:outline-none"
          >Oh of One Web Design</a
        >
      </p>
      <ul class="flex flex-wrap gap-6" role="list">
        <li>
          <a
            href="/privacy-policy"
            class="hover:text-brand-fg-muted focus:ring-offset-brand text-sm transition-all focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
            >Privacy Policy</a
          >
        </li>
        <li>
          <a
            href="/terms-of-use"
            class="hover:text-brand-fg-muted focus:ring-offset-brand text-sm transition-all focus:ring-2 focus:ring-white focus:ring-offset-2 focus:outline-none"
            >Terms of Use</a
          >
        </li>
      </ul>
    </div>
  </div>
</footer>

<!-- Toast notification -->
<div
  id="contact-toast"
  role="status"
  aria-live="polite"
  aria-atomic="true"
  class="fixed right-4 bottom-4 z-50 flex translate-y-4 items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium opacity-0 shadow-lg transition-all duration-300"
>
  <span id="contact-toast-icon" aria-hidden="true"></span>
  <span id="contact-toast-message"></span>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const yearSpan = document.getElementById("footer-year");
    if (yearSpan) {
      yearSpan.textContent = String(new Date().getFullYear());
    }

    const form = document.querySelector<HTMLFormElement>(
      'form[aria-label="Contact form"]',
    );
    const toast = document.getElementById("contact-toast")!;
    const toastMessage = document.getElementById("contact-toast-message")!;
    const toastIcon = document.getElementById("contact-toast-icon")!;
    let dismissTimer: ReturnType<typeof setTimeout>;

    function showToast(success: boolean) {
      clearTimeout(dismissTimer);

      if (success) {
        toast.className = toast.className
          .replace(/bg-\S+/g, "")
          .replace(/text-\S+/g, "")
          .trim();
        toast.classList.add(
          "bg-zinc-900",
          "text-white",
          "border",
          "border-zinc-700",
        );
        toastIcon.textContent = "✓";
        toastMessage.textContent = "Message sent! We'll be in touch soon.";
      } else {
        toast.className = toast.className
          .replace(/bg-\S+/g, "")
          .replace(/text-\S+/g, "")
          .trim();
        toast.classList.add(
          "bg-red-900",
          "text-white",
          "border",
          "border-red-700",
        );
        toastIcon.textContent = "✕";
        toastMessage.textContent = "Something went wrong. Please try again.";
      }

      toast.classList.remove("opacity-0", "translate-y-4");
      toast.classList.add("opacity-100", "translate-y-0");

      dismissTimer = setTimeout(() => {
        toast.classList.remove("opacity-100", "translate-y-0");
        toast.classList.add("opacity-0", "translate-y-4");
      }, 4000);
    }

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Wire up your submission logic here (e.g. fetch to an API endpoint).
      // showToast(true) on success, showToast(false) on failure.
      showToast(true);
    });
  });
</script>
