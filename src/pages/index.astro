---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/header.astro";
import FooterBasic from "../components/footer-basic.astro";

const menuItems = [
  {
    name: "Services",
    href: "/#services",
  },
  {
    name: "Call",
    href: "/#call",
  },
];

const logo = "Logo";
const companyName = "Smith & Sons Plumbing";
---

<BaseLayout>
  <Header menuItems={menuItems} logo={logo} slot="header" />
  <FooterBasic companyName={companyName} slot="footer" />
</BaseLayout>
